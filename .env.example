# Frontend Environment Variables
# Copy this file to .env and fill in your values

# WalletConnect / Web3Modal project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_PROJECT_ID=your_walletconnect_project_id_here

# Arbitrum Sepolia RPC URL (parent chain for bridging and provider)
NEXT_PUBLIC_INFURA_RPC=https://arb-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# Arbitrum Sepolia RPC (used by Orbit chain config)
L1RPC=https://arb-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# Faucet — server-side only (no NEXT_PUBLIC_ prefix)
FAUCET_PASSWORD=your_faucet_password_here
FAUCET_PRIVATE_KEY=your_faucet_wallet_private_key_here

# Skip Create React App preflight check
SKIP_PREFLIGHT_CHECK=true
